#! /usr/bin/sh
# vim: foldmethod=marker foldlevel=0


# Usage Message {{{
USAGE="
SYNOPSYS
    ${0##*/} [options] -- [directories...]

DESCRIPTION
    List files in one or more directory trees and do something with them. If no
    root directory is given, the CWD is used.

OPTIONS
    -h, --help
        Displays this usage information and exits

NOTE
    If the names of your directories conflict with those of the flags, put them
    after a double dash (--), like this:
        ${0##*/} -- --help
    This will act upon a directory called '--help', instead of activating the
    '--help' switch.
"
# }}}


# Constants are UPPERCASE
readonly PREVIEW_SCRIPT="${SCRIPTS:-$HOME/scripts}/snow-preview.sh" 
readonly BAT_PAGER="bat --paging=always --style=plain"

readonly FZF_HEADER="\
Files from: ${*:-"$(pwd)"}
(Shift-)Tab to (de)select
Ctrl + ( [V]im  [L]ess  [O]pen  [P]rint  [Y]ank  [W]rap  [R]otate )"


# Global (mutable) variables are g_* prefixed
g_pos_args=
g_fzf_bind_commands="\
ctrl-v:become(${EDITOR:-vim} -p {+}),\
ctrl-l:execute(echo {+} | xargs printf '%s\0' | xargs -0I [file] sh -c '$PREVIEW_SCRIPT [file] | $BAT_PAGER')+clear-selection,\
ctrl-o:become(echo {+} | xargs --max-args=1 detach xdg-open),\
ctrl-p:accept-non-empty,\
ctrl-y:execute(printf '%s\n' {+} | xsel -ib),\
ctrl-w:toggle-preview-wrap,\
esc:cancel,\
enter:ignore" 


fatal() {
    # {{{
    >&2 echo "$@"
    exit 1
} # }}}


init_preview_window() {
    # Preview window settings and bindings (rotation) {{{
    key_rotate=ctrl-r
    wide_preview=right,70%
    tall_preview=top,60%
    _col_count="$(stty -a | grep -Po '(?<=columns )\d+')"
    if [ "$_col_count" -ge 160 ]; then
        fzf_preview_window=$wide_preview
        g_fzf_bind_commands="$g_fzf_bind_commands,$key_rotate:change-preview-window($tall_preview|$wide_preview)"
    else
        fzf_preview_window=$tall_preview
        g_fzf_bind_commands="$g_fzf_bind_commands,$key_rotate:change-preview-window($wide_preview|$tall_preview)"
    fi
} # }}}


find_files() {
    # {{{
    if   command -v rg   >/dev/null 2>&1; then
        rg --files --null "$@"

    elif command -v find >/dev/null 2>&1; then
        find "$@" \
             \( -iname .git \
            -or -iname .svn \
            -or -iname .cvs \
            -or -iname .hg  \
            -or -iname node_modules \
        \) -prune -o -print0

    else
        >&2 echo "couldn't find_files() because you got no programs in your system."
    fi
} # }}}


parse_cli_args() {
    # {{{
    # NOTE: functions like this CAN NOT be called inside subshells $(myfunc)
    # because they will modify variables that, upon return, will STAY on those
    # subshells and, thus, the globals defined in the calling instance WILL NOT
    # be modified (and that's a bug).
    args="$(getopt -o "h" -l "help" -n "snow" -- "$@")" \
        || fatal "Error parsing arguments!"
    eval set -- "$args"

    while true; do
        case "$1" in
            '-h'|'--help') >&2 echo "$USAGE"; exit 0 ;;
            '--') shift; break ;;
        esac
    done

    g_pos_args="$@" # Return remaining (positional) arguments
} # }}}


main() {

    parse_cli_args "$@"
    eval set -- "$g_pos_args"
    init_preview_window

    find_files "$@" \
        | sort -z \
        | fzf \
            -i --multi \
            --read0 --print0 \
            --info=inline --header="$FZF_HEADER" --header-first \
            --preview="$PREVIEW_SCRIPT {}" \
            --preview-window="$fzf_preview_window" \
            --bind="$g_fzf_bind_commands"
}

main "$@"

